data "aws_availability_zones" "available" {
  state = "available"
}

#vpc 및 네트워크 생성
module "project01_vpc" {
  source     = "../../modules/vpc"
  cidr_block = "10.0.0.0/16"
  name       = "project01-vpc"
}

#igw 인터넷 게이트웨이 생성
module "igw" {
  source  = "../../modules/internet-gateway"
  vpc_id  = module.project01_vpc.vpc_id
  name    = "project01-igw"
}

# subnet-module || public bastion 서브넷 생성
module "project01_public_subnet_bastion" {
  source = "../../modules/subnet"

  vpc_id            = module.project01_vpc.vpc_id
  cidr_block        = "10.0.1.0/24"
  az                = data.aws_availability_zones.available.names[0]
  map_public_ip     = true
  name              = "project01-public-subnet-bastion"
}

# subnet-module || private was 서브넷 생성
module "project01_private_subnet_was" {
  source = "../../modules/subnet"

  vpc_id            = module.project01_vpc.vpc_id
  cidr_block        = "10.0.10.0/24"
  az                = data.aws_availability_zones.available.names[0]

  map_public_ip     = false
  name              = "project01-private-subnet-was"
}

# subnet-module || private was 서브넷 생성 -- 삭제예정
module "project01_private_subnet_was_alb" {
  source = "../../modules/subnet"

  vpc_id            = module.project01_vpc.vpc_id
  cidr_block        = "10.0.20.0/24"
  az                = data.aws_availability_zones.available.names[1]

  map_public_ip     = false
  name              = "project01-private-subnet-was-alb"
}

# subnet-module || private db 서브넷 생성
module "project01_private_subnet_db" {
  source = "../../modules/subnet"

  vpc_id            = module.project01_vpc.vpc_id
  cidr_block        = "10.0.30.0/24"
  az                = data.aws_availability_zones.available.names[0]

  map_public_ip     = false
  name              = "project01-private-subnet-db"
}


# subnet-module || public alb 서브넷 생성
module "project01_public_subnet_alb_a" {
  source = "../../modules/subnet"

  vpc_id            = module.project01_vpc.vpc_id
  cidr_block        = "10.0.2.0/24"
  az                = data.aws_availability_zones.available.names[0]
  map_public_ip     = true
  name              = "project01-public-subnet-alb-a"
}

# subnet-module || public alb 서브넷 생성
module "project01_public_subnet_alb_b" {
  source = "../../modules/subnet"

  vpc_id            = module.project01_vpc.vpc_id
  cidr_block        = "10.0.3.0/24"
  az                = data.aws_availability_zones.available.names[1]
  map_public_ip     = true
  name              = "project01-public-subnet-alb-b"
}



# 라우팅 테이블 : 트레픽 이정표 
resource "aws_route_table" "project01_public_rt" {
    # 어떤 vpc 의 소속인지 설정 
    vpc_id = module.project01_vpc.vpc_id
    # 라우팅 규칙 (0.0.0.0/0) 으로 가는 트레픽은 인터넷 게이트(igw) 웨이로 보내라
    route {
        cidr_block = "0.0.0.0/0"
        gateway_id = module.igw.igw_id
    }
	tags = {
		Name = "project01-public-rt"
	}
}

# public subnet 을 위의 라우팅 테이블로 연결
resource  "aws_route_table_association" "project01_public_add__bastion_rt" {	
	subnet_id       = module.project01_public_subnet_bastion.subnet_id # 생성한 퍼블릭 서브넷은
    route_table_id  = aws_route_table.project01_public_rt.id # 위에서 만든 라우팅 테이블로 연결 	
}

# public subnet 을 위의 라우팅 테이블로 연결
resource  "aws_route_table_association" "project01_public_add_alb_a_rt" {	
	subnet_id       = module.project01_public_subnet_alb_a.subnet_id # 생성한 퍼블릭 서브넷은
    route_table_id  = aws_route_table.project01_public_rt.id # 위에서 만든 라우팅 테이블로 연결 	
}

# public subnet 을 위의 라우팅 테이블로 연결
resource  "aws_route_table_association" "project01_public_add_alb_b_rt" {	
	subnet_id       = module.project01_public_subnet_alb_b.subnet_id # 생성한 퍼블릭 서브넷은
    route_table_id  = aws_route_table.project01_public_rt.id # 위에서 만든 라우팅 테이블로 연결 	
}


module "project01_bastion_sg" {
  source = "../../modules/security-group"

  name   = "project01-bastion-sg"
  vpc_id = module.project01_vpc.vpc_id

  ingress_rules = [
    {
      from_port   = 22
      to_port     = 22
      protocol    = "tcp"
      cidr_blocks = ["0.0.0.0/0"]
	  description = "SSH access (bastion)"
    },
    {
      from_port   = 80
      to_port     = 80
      protocol    = "tcp"
      cidr_blocks = ["0.0.0.0/0"]
	  description = "HTTP web traffic"
    }
  ]

  egress_rules = [
    {
      from_port   = 0
      to_port     = 0
      protocol    = "-1"
      cidr_blocks = ["0.0.0.0/0"]
	  description = null
    }
  ]
}

# 보안그룹 생성 - project01 was
module "project01_was_sg" {
  source = "../../modules/security-group"

  name   = "project01-was-sg"
  vpc_id = module.project01_vpc.vpc_id

  ingress_rules = [
    {
      from_port   = 22
      to_port     = 22
      protocol    = "tcp"
	  #cidr_blocks = ["${module.project01_bastion_ec2.private_ip}/32"]
	  security_groups = [module.project01_bastion_sg.sg_id]      
	  description = "SSH access (bastion)"
    },	
    {
      from_port   = 80
      to_port     = 80
      protocol    = "tcp"
      #cidr_blocks = ["0.0.0.0/0"]
	  #description = "HTTP web traffic"
	  security_groups = [module.project01_alb_sg.sg_id]
	  description = "alb HTTP web traffic"
    },
    {
      from_port   = 443
      to_port     = 443
      protocol    = "tcp"
      #cidr_blocks = ["0.0.0.0/0"]
	  #description = "HTTPS web traffic"
	  security_groups = [module.project01_alb_sg.sg_id]
	  description = "alb HTTPS web traffic"
    }	
  ]

  egress_rules = [
    {
      from_port   = 0
      to_port     = 0
      protocol    = "-1"
      cidr_blocks = ["0.0.0.0/0"]
	  description = null
    }
  ]
}

# 보안그룹 생성 - project01 db
module "project01_db_sg" {
  source = "../../modules/security-group"

  name   = "project01-db-sg"
  vpc_id = module.project01_vpc.vpc_id

  ingress_rules = [
    {
      from_port   = 22
      to_port     = 22
      protocol    = "tcp"
	  #cidr_blocks = ["${module.project01_bastion_ec2.private_ip}/32"]
	  security_groups = [module.project01_bastion_sg.sg_id] 
	  description = "SSH access (bastion)"
    },
    {
      from_port   = 5432
      to_port     = 5432
      protocol    = "tcp"
	  #cidr_blocks = ["${module.project01_bastion_ec2.private_ip}/32"]
	  security_groups = [module.project01_was_sg.sg_id]
	  description = "PostgreSql access (was)"
    }    
  ]

  egress_rules = [
    {
      from_port   = 0
      to_port     = 0
      protocol    = "-1"
      cidr_blocks = ["0.0.0.0/0"]
	  description = null
    }
  ]
}


# ec2-module || bastion-mgmt 서버 생성 (public)
module "project01_bastion_ec2" {
  source = "../../modules/ec2"

  instance_type      = "t3.micro"
  subnet_id          = module.project01_public_subnet_bastion.subnet_id  
  security_group_ids = [module.project01_bastion_sg.sg_id]
  key_name           = "project01-key-mgmt"
  name               = "project01_bastion_ec2"
}

# ec2-module || project01-was 서버 생성 (private)
module "project01_was01_ec2" {
  source = "../../modules/ec2"

  instance_type      = "t3.micro"
  subnet_id          = module.project01_private_subnet_was.subnet_id  
  security_group_ids = [module.project01_was_sg.sg_id]
  key_name           = "project01-key-was"
  name               = "project01-was01-ec2"
}

# ec2-module || project01-db 서버 생성 (private)
module "project01_db_ec2" {
  source = "../../modules/ec2"

  instance_type      = "t3.micro"
  subnet_id          = module.project01_private_subnet_db.subnet_id  
  security_group_ids = [module.project01_db_sg.sg_id]
  key_name           = "project01-key-was"
  name               = "project01_db_ec2"
}

# NAT-GATEWAY 설정
module "project01_ngw" {
  source    = "../../modules/nat-gateway"
  subnet_id = module.project01_public_subnet_bastion.subnet_id
  name      = "project01-ngw"
}

#Private Subnet 라우팅 테이블 연결 (생성) // VPC > Subnet > NAT > Route Table > Association
resource "aws_route_table" "project01_private_rt" {
  vpc_id = module.project01_vpc.vpc_id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = module.project01_ngw.nat_gateway_id
  }

  # NAT Gateway 생성되기 전 route table 생성 시도 방지
  depends_on = [module.project01_ngw]

  tags = {
    Name = "project01-private-rt"
  }
}

# NAT 서브넷 연결 (private - was) // VPC > Subnet > NAT > Route Table > Association
resource "aws_route_table_association" "private_was_add_rt" {
  subnet_id      = module.project01_private_subnet_was.subnet_id
  route_table_id = aws_route_table.project01_private_rt.id
}
# NAT 서브넷 연결 (private - db) // VPC > Subnet > NAT > Route Table > Association
resource "aws_route_table_association" "private_db_add_rt" {
  subnet_id      = module.project01_private_subnet_db.subnet_id
  route_table_id = aws_route_table.project01_private_rt.id
}


###########################################################
######################### 로드밸런서#########################
module "project01_alb" {
  source = "../../modules/alb"

  name     = "project01-alb"
  vpc_id   = module.project01_vpc.vpc_id

  subnet_ids = [
	#module.project01_private_subnet_was.subnet_id,
	#module.project01_private_subnet_was_alb.subnet_id
	module.project01_public_subnet_alb_a.subnet_id,
	module.project01_public_subnet_alb_b.subnet_id
  ]

  security_group_ids = [module.project01_alb_sg.sg_id]

/*
  target_instance_ids = [
    module.project01_was01_ec2.instance_id
  ]
*/
  target_instance_ids = {
    was = module.project01_was01_ec2.instance_id
  }
}

#ALB용 Security Group 추가
module "project01_alb_sg" {
  source = "../../modules/security-group"

  name   = "project01-alb-sg"
  vpc_id = module.project01_vpc.vpc_id

  ingress_rules = [
    {
      from_port   = 80
      to_port     = 80
      protocol    = "tcp"
      cidr_blocks = ["0.0.0.0/0"]
      description = "HTTP from internet"
    },
	{
      from_port   = 443
      to_port     = 443
      protocol    = "tcp"
      cidr_blocks = ["0.0.0.0/0"]
      description = "HTTPS from internet"
    }
  ]

  egress_rules = [
    {
      from_port   = 0
      to_port     = 0
      protocol    = "-1"
      cidr_blocks = ["0.0.0.0/0"]
      description = null
    }
  ]
}
